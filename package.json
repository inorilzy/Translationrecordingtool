{
  "name": "translation-tool",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:dictionary": "python scripts/build_dictionary.py",
    "ocr:server": "npm run ocr:server:paddle",
    "ocr:server:paddle": "uv run --python 3.11 --with paddleocr==2.7.3 --with paddlepaddle==2.6.2 --with \"numpy<2\" python scripts/paddle_ocr_server.py --engine paddleocr",
    "ocr:server:rapid": "uv run --python 3.11 --with rapidocr-onnxruntime==1.4.4 --with onnxruntime==1.16.3 --with \"numpy<2\" python scripts/paddle_ocr_server.py --engine rapidocr",
    "ocr:sidecar:win": "powershell -ExecutionPolicy Bypass -File scripts/build_ocr_sidecar.ps1",
    "ocr:models:win": "powershell -ExecutionPolicy Bypass -File scripts/prepare_ocr_models.ps1",
    "tauri:build:ocr": "npm run ocr:sidecar:win && tauri build --config src-tauri/tauri.ocr-sidecar.conf.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:component": "vitest run",
    "test:e2e": "playwright test",
    "verify:final": "node scripts/verify-s06.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@lucide/vue": "^1.21.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "@unocss/reset": "^66.7.2",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@unocss/preset-uno": "^66.7.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/ui": "^4.1.4",
    "@vue/test-utils": "^2.4.8",
    "jsdom": "^29.0.2",
    "typescript": "~5.6.2",
    "unocss": "^66.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.1.10"
  }
}
